# ── Android / Gradle build artifacts ──────────────────────────────────────────
.gradle/
build/
/app/build/
*.apk
*.aab

# ── Machine-specific ──────────────────────────────────────────────────────────
# SDK path differs per machine
local.properties
# NDK/CMake intermediate build files
.cxx/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
*.iml
.DS_Store
# Kotlin compiler daemon / incremental caches
.kotlin/

# ── Capture output (large; not source) ────────────────────────────────────────
/captures/

# Never commit device secrets
pixel-pin
*.pin

# build logs
gradle_build.log

# Python backend caches
backend/__pycache__/
