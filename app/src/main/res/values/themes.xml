<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Activity-level theme. The real UI/colors live in Compose (RumahkuTheme);
      this base theme sets edge-to-edge, a warm brand window background (so
      launches/transitions don't flash black), gentle fade transitions, and a
      branded splash (API 31+).
    -->
    <style name="Theme.Rumahku" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/brand_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowAnimationStyle">@style/RumahkuWindowAnim</item>
        <item name="android:windowSplashScreenBackground">@color/brand_primary</item>
    </style>

    <!-- Dark screens over a camera/black background (Capture, the fullscreen
         viewer): black window + light (white) status-bar icons. -->
    <style name="Theme.Rumahku.Dark" parent="Theme.Rumahku">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="RumahkuWindowAnim">
        <item name="android:activityOpenEnterAnimation">@anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/fade_out</item>
    </style>
</resources>
