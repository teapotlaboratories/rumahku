<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Camera is the core sensor for scanning. ARCore drives it for us. -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- On-device reconstruction runs as a foreground service (multi-minute GPU
         work) so it survives backgrounding / screen-lock. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Declares the app uses the camera and (via ARCore) needs AR support.
         required=true means the Play Store will only offer the app to
         AR-capable devices. -->
    <uses-feature android:name="android.hardware.camera.ar" android:required="true" />

    <!-- OpenGL ES 3.0 is needed for ARCore's camera background rendering. -->
    <uses-feature android:glEsVersion="0x00030000" android:required="true" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Rumahku">

        <!-- Tells Google Play Services for AR to auto-install/verify ARCore.
             "required" = device must have ARCore for the app to run. -->
        <meta-data android:name="com.google.ar.core" android:value="required" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.Rumahku">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The live scanning screen. configChanges lets it survive rotation
             without being recreated (ARCore handles rotation itself). -->
        <activity
            android:name=".CaptureActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.Rumahku.Dark" />

        <!-- Reconstruction progress screen. -->
        <activity
            android:name=".ReconstructionActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.Rumahku" />

        <!-- On-device splat viewer (M4) — immersive/dark theme. -->
        <activity
            android:name=".SplatViewerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.Rumahku.Dark" />

        <!-- Lets us share the exported .ply to other apps via a content:// URI. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Runs BrushTrainer.nativeTrain in the foreground so a multi-minute
             reconstruction isn't killed when the app is backgrounded. -->
        <service
            android:name=".ReconstructionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
